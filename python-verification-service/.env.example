# ── BookVibe KYC / Verification Service ──
# Production providers: Google Cloud Vision (CNIC OCR) + AWS Rekognition (face match + liveness).

# AWS Credentials — required for face matching & liveness (AWS Rekognition)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Google Cloud Credentials — required for CNIC OCR (Google Vision API)
# Absolute path to your service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/google-service-account.json

# CORS — comma-separated origins allowed to call this service.
# Only the Node backend should ever call it.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Shared secret with the Node backend. When set, every verification endpoint
# requires a matching X-Internal-Key header (set PYTHON_INTERNAL_KEY to the same
# value in the backend .env). Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# Decision Thresholds (0-100)
THRESHOLD_APPROVED=85.0
THRESHOLD_REJECTED=50.0
