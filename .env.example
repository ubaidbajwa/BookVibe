# Root-level env used ONLY by docker-compose for build-arg substitution.
# Copy to ".env" (next to docker-compose.yml) and fill in.
#
#   cp .env.example .env
#
# The secret admin route segment baked into the frontend build.
# Use ONLY the path segment (no domain, no leading slash), e.g. ctrl-bv5ap6
VITE_ADMIN_PATH=ctrl-bv5ap6
