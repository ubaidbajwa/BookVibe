# Root-level env used ONLY by docker-compose for build-arg substitution.
# Copy to ".env" (next to docker-compose.yml) and fill in.
#
#   cp .env.example .env
#
# The secret admin route segment baked into the frontend build.
# Use ONLY the path segment (no domain, no leading slash), e.g. ctrl-bv5ap6
VITE_ADMIN_PATH=ctrl-bv5ap6

# AWS Face Liveness (browser) — see AWS_FACE_LIVENESS_SETUP.md
# Must be a Face-Liveness-supported region (e.g. us-east-1, us-west-2, eu-west-1).
VITE_AWS_REGION=us-east-1
# Cognito Identity Pool id that grants guests rekognition:StartFaceLivenessSession.
VITE_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
